{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "your-super-secret-key-change-this-in-production-minimum-32-characters",
    "Issuer": "ams-issuer",
    "Audience": "ams-audience",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://your-frontend-domain.com"
    ]
  },
  "Database": {
    "ConnectionString": "Server=.;Database=AttendanceManagementSystem;Trusted_Connection=true;Encrypt=false;",
    "Provider": "SqlServer"
  },
  "RateLimiting": {
    "MaxRequests": 100,
    "TimeWindowSeconds": 60
  },
  "ApiSettings": {
    "ApiVersion": "1.0",
    "BaseUrl": "https://api.ams.local",
    "EnableSwagger": true,
    "EnableCors": true
  }
}
