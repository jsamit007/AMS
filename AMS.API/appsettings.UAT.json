{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "uat-secret-key-change-this-minimum-32-characters-uat-env",
    "Issuer": "ams-issuer-uat",
    "Audience": "ams-audience-uat",
    "ExpirationMinutes": 180
  },
  "Cors": {
    "AllowedOrigins": [
      "https://uat-ams.yourdomain.com",
      "https://uat-frontend.yourdomain.com"
    ]
  },
  "Database": {
    "ConnectionString": "Host=uat-db-server;Port=5432;Database=ams_uat;Username=postgres;Password=YourUATPassword;",
    "Provider": "PostgreSQL"
  },
  "RateLimiting": {
    "MaxRequests": 100,
    "TimeWindowSeconds": 60
  },
  "ApiSettings": {
    "ApiVersion": "1.0",
    "BaseUrl": "https://uat-ams.yourdomain.com/api",
    "EnableSwagger": false,
    "EnableCors": true
  },
  "CloudWatch": {
    "Enabled": true,
    "LogGroupName": "/ams/api/uat",
    "LogStreamName": "uat-server",
    "Region": "us-east-1",
    "AccessKey": "YOUR_AWS_ACCESS_KEY",
    "SecretKey": "YOUR_AWS_SECRET_KEY"
  }
}
