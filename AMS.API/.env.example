# Environment Variables for AMS API
# Copy this file to .env and update with your values
# Note: Use double underscores (__) for nested configuration in environment variables

# Development Environment
# ASPNETCORE_ENVIRONMENT=Development

# QA Environment
# ASPNETCORE_ENVIRONMENT=QA

# UAT Environment
# ASPNETCORE_ENVIRONMENT=UAT

# Production Environment
# ASPNETCORE_ENVIRONMENT=Production

# JWT Configuration (overrides appsettings)
# Jwt__SecretKey=your-secret-key-here-minimum-32-characters
# Jwt__Issuer=ams-issuer
# Jwt__Audience=ams-audience
# Jwt__ExpirationMinutes=60

# Database Configuration (overrides appsettings)
# Database__ConnectionString=Server=.;Database=AttendanceManagementSystem;Trusted_Connection=true;

# CORS Configuration (overrides appsettings)
# Cors__AllowedOrigins__0=http://localhost:3000
# Cors__AllowedOrigins__1=http://localhost:5173

# Logging Configuration (overrides appsettings)
# Logging__LogLevel__Default=Information
# Logging__LogLevel__Microsoft.AspNetCore=Warning

# API Settings
# ApiSettings__BaseUrl=http://localhost:5000
# ApiSettings__EnableSwagger=true
# ApiSettings__EnableCors=true

# Rate Limiting
# RateLimiting__MaxRequests=100
# RateLimiting__TimeWindowSeconds=60

# CloudWatch Logging Configuration (overrides appsettings)
# CloudWatch__Enabled=true
# CloudWatch__LogGroupName=/ams/api/production
# CloudWatch__LogStreamName=prod-server-01
# CloudWatch__Region=us-east-1

# AWS Credentials for CloudWatch
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=us-east-1

# Serilog Configuration (optional)
# Serilog__MinimumLevel=Information
# Serilog__WriteTo__0__Name=Console
# Serilog__WriteTo__1__Name=File
