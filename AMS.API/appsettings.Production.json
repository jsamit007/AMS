{
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "production-secret-key-change-this-minimum-32-characters-prod-mode",
    "Issuer": "ams-issuer-prod",
    "Audience": "ams-audience-prod",
    "ExpirationMinutes": 240
  },
  "Cors": {
    "AllowedOrigins": [
      "https://ams.yourdomain.com",
      "https://frontend.yourdomain.com"
    ]
  },
  "Database": {
    "ConnectionString": "Host=prod-db-server;Port=5432;Database=ams_prod;Username=postgres;Password=YourProductionPassword;",
    "Provider": "PostgreSQL"
  },
  "RateLimiting": {
    "MaxRequests": 100,
    "TimeWindowSeconds": 60
  },
  "ApiSettings": {
    "ApiVersion": "1.0",
    "BaseUrl": "https://ams.yourdomain.com/api",
    "EnableSwagger": false,
    "EnableCors": true
  },
  "CloudWatch": {
    "Enabled": true,
    "LogGroupName": "/ams/api/production",
    "LogStreamName": "prod-server",
    "Region": "us-east-1",
    "AccessKey": "YOUR_AWS_ACCESS_KEY",
    "SecretKey": "YOUR_AWS_SECRET_KEY"
  }
}
